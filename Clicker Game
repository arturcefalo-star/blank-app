import streamlit as st

st.title("alooooo")

if "pontos" not in st.session_state:
    st.session_state.pontos = 0

if "poder_clique" not in st.session_state:
    st.session_state.poder_clique = 1

def adicionar_ponto():
    st.session_state.pontos += st.session_state.poder_clique

def comprar_melhoria():
    if st.session_state.pontos >= 100:
        st.session_state.pontos -= 100
        st.session_state.poder_clique += 1
    else:
        st.session_state.erro_dinheiro = True

st.button("            Click Here          ", on_click=adicionar_ponto)


st.write(f"Pontos: {st.session_state.pontos}")
st.write(f"Poder de clique: {st.session_state.poder_clique}")


st.button("Melhoria +1 = 100 Pontos", on_click=comprar_melhoria, use_container_width=True)

if "erro_dinheiro" in st.session_state and st.session_state.erro_dinheiro:
    st.error("Pontos Insuficiente")
    st.session_state.erro_dinheiro = False

